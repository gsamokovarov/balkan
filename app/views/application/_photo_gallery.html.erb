<%# locals: (photos:) %>

<% urls = photos.map { url_for try_variant(it, resize_to_limit: [1400, 1400]) } %>

<div class="relative -mx-4 px-4 sm:mx-0 sm:px-0" data-controller="gallery" data-gallery-urls-value="<%= urls.to_json %>">
  <div class="aspect-video overflow-hidden rounded-md border-2 border-black bg-black">
    <%= image_tag "", alt: "Event photo", class: "h-full w-full object-contain", data: { gallery_target: "image" } %>
  </div>

  <% if photos.size > 1 %>
    <button type="button" aria-label="Previous photo"
      class="absolute left-6 top-1/2 -translate-y-1/2 rounded-full border-2 border-black bg-white/90 px-3 py-1 text-xl font-bold leading-none hover:bg-white sm:left-2"
      data-action="gallery#previous">&lsaquo;</button>

    <button type="button" aria-label="Next photo"
      class="absolute right-6 top-1/2 -translate-y-1/2 rounded-full border-2 border-black bg-white/90 px-3 py-1 text-xl font-bold leading-none hover:bg-white sm:right-2"
      data-action="gallery#next">&rsaquo;</button>

    <div class="absolute bottom-2 right-6 rounded-md bg-black/70 px-2 py-1 text-sm font-medium text-white sm:right-2" data-gallery-target="counter"></div>
  <% end %>
</div>
