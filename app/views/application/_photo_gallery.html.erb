<%# locals: (photos:) %>

<% urls = photos.map { url_for try_variant(it, resize_to_limit: [1400, 1400]) } %>

<div class="relative -mx-4 px-4 sm:mx-0 sm:px-0" data-controller="gallery" data-gallery-urls-value="<%= urls.to_json %>" data-action="touchstart->gallery#swipeStart touchend->gallery#swipeEnd">
  <div class="aspect-video overflow-hidden rounded-md border-2 border-black bg-black cursor-zoom-in" data-action="click->gallery#open">
    <%= image_tag "", alt: "Event photo", class: "h-full w-full object-contain", data: { gallery_target: "image" } %>
  </div>

  <% if photos.size > 1 %>
    <button type="button" aria-label="Previous photo"
      class="absolute left-6 top-1/2 -translate-y-1/2 cursor-pointer select-none rounded-full bg-white/10 px-4 py-2 text-3xl font-bold leading-none text-white hover:bg-white/20 sm:left-2"
      data-action="gallery#previous">&lsaquo;</button>

    <button type="button" aria-label="Next photo"
      class="absolute right-6 top-1/2 -translate-y-1/2 cursor-pointer select-none rounded-full bg-white/10 px-4 py-2 text-3xl font-bold leading-none text-white hover:bg-white/20 sm:right-2"
      data-action="gallery#next">&rsaquo;</button>

    <div class="absolute bottom-2 right-6 rounded-md bg-white/10 px-3 py-1 text-sm font-medium text-white sm:right-2" data-gallery-target="counter"></div>
  <% end %>

  <dialog class="fixed inset-0 m-0 h-dvh max-h-none w-dvw max-w-none items-center justify-center bg-black/95 p-4 open:flex sm:p-8" aria-label="Photo gallery" data-gallery-target="overlay" data-action="click->gallery#backdropClose keydown.left->gallery#previous keydown.right->gallery#next">
    <%= image_tag "", alt: "Event photo", class: "max-h-full max-w-full object-contain", data: { gallery_target: "image" } %>

    <button type="button" aria-label="Close gallery"
      class="absolute right-4 top-4 cursor-pointer select-none rounded-full bg-white/10 px-4 py-2 text-3xl font-bold leading-none text-white hover:bg-white/20"
      data-action="gallery#close">&times;</button>

    <% if photos.size > 1 %>
      <button type="button" aria-label="Previous photo"
        class="absolute left-4 top-1/2 -translate-y-1/2 cursor-pointer select-none rounded-full bg-white/10 px-4 py-2 text-3xl font-bold leading-none text-white hover:bg-white/20"
        data-action="gallery#previous">&lsaquo;</button>

      <button type="button" aria-label="Next photo"
        class="absolute right-4 top-1/2 -translate-y-1/2 cursor-pointer select-none rounded-full bg-white/10 px-4 py-2 text-3xl font-bold leading-none text-white hover:bg-white/20"
        data-action="gallery#next">&rsaquo;</button>

      <div class="absolute bottom-6 left-1/2 -translate-x-1/2 rounded-md bg-white/10 px-3 py-1 text-sm font-medium text-white" data-gallery-target="counter"></div>
    <% end %>
  </dialog>
</div>
