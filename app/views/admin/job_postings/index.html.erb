<%= section_navigation :partnerships %>

<%= render "section", title: "Job postings", cta: -> {
  admin_button(:primary, link: new_admin_event_job_posting_path) { "New job posting" }
} do %>
  <% if @job_postings.any? %>
    <%= render "job_postings", job_postings: @job_postings %>
  <% else %>
    <%= render "empty_state" do %>
      <% admin_button(:primary, link: new_admin_event_job_posting_path) { "New job posting" } %>
    <% end %>
  <% end %>
<% end %>
