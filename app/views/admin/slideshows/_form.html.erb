<%# locals: (slideshow:) %>

<div class="flex flex-col md:flex-row md:space-x-6">
  <%= admin_form slideshow, url: admin_event_slideshow_path(slideshow.event), html: { class: "sm:max-w-sm flex-1" } do |f| %>
    <%= f.text_area_input :content, required: true, rows: 30 %>
    <%= f.submit %>
  <% end %>

  <div class="w-full sm:w-96">
    <div class="p-2 border border-gray-300 rounded-md shadow-sm mb-6">
      <p class="font-medium text-sm mb-2 text-gray-900 dark:text-gray-100">Liquid variables:</p>
      <div class="grid grid-cols-2 gap-2 text-xs text-gray-600 dark:text-gray-400">
        <p class="col-span-2 font-medium text-gray-700 dark:text-gray-300 mt-2">Event</p>
        <code>{{ event_title }}</code>
        <code>{{ event_subtitle }}</code>
        <code>{{ event_host }}</code>
        <code>{{ event_dates }}</code>
        <code>{{ event_logo }}</code>
        <code>{{ ticket_count }}</code>
        <code>{{ qr_code }}</code>

        <p class="col-span-2 font-medium text-gray-700 dark:text-gray-300 mt-2">Schedule</p>
        <code>{{ talk_N }}</code>
        <code>{{ break_N }}</code>
        <code>{{ day }}</code>

        <p class="col-span-2 font-medium text-gray-700 dark:text-gray-300 mt-2">People</p>
        <code>{{ mc_N }}</code>
        <code>{{ community_partners }}</code>
        <code>{{ sponsors }}</code>
        <code>{{ partner_name }}</code>

        <p class="col-span-2 font-medium text-gray-700 dark:text-gray-300 mt-2">Syntax</p>
        <code>---</code>
        <code>{% if day == 0 %}</code>
      </div>
    </div>
  </div>
</div>
