<%= render "section", title: "User #{@user.email}" do %>
  <%= render "form", user: @user %>
<% end %>

<% if Current.user.organizer? && @user.incomplete? %>
  <%= render "section", title: "Activation link", description: "This user hasn't set a password yet. Send them this one-time link to finish setup." do %>
    <%= render "activation", user: @user %>
  <% end %>
<% end %>

<%= render "section", title: "Sessions" do %>
  <% if @user.sessions.any? %>
    <%= render "sessions", sessions: @user.sessions.order(id: :desc) %>
  <% else %>
    <%= render "empty_state" %>
  <% end %>
<% end %>
