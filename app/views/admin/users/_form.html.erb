<%# locals: (user:) %>

<%= admin_form [:admin, user] do |f| %>
  <%= f.text_input :name, required: true %>
  <%= f.email_input :email, required: true  %>
  <%= f.password_input :password %>
  <%= f.text_area_input :bio %>
  <%= f.file_input :avatar %>
  <% if Current.user&.organizer? %>
    <%= f.enum_input :role, User.roles, selected: user.role || :staff %>
  <% end %>

  <%= f.submit %>
<% end %>
