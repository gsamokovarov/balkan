<%# locals: (user:) %>

<% url = admin_invitation_url(user.generate_token_for(:invitation)) %>

<div data-controller="clipboard" class="flex flex-col gap-3 sm:flex-row sm:items-center">
  <code data-clipboard-target="source" class="flex-1 select-all break-all rounded-md bg-gray-100 px-3 py-2 font-mono text-sm text-gray-900 dark:bg-gray-800 dark:text-gray-100"><%= url %></code>
  <%= admin_button(:primary, type: "button", data: { action: "clipboard#copy" }) { "Copy" } %>
</div>
