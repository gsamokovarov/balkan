<%# locals: (highlight: false) %>

<%= render "section", title: "Community partners", highlight: do %>
  <div class="grid grid-cols-2 gap-3 sm:gap-6 lg:grid-cols-3">
    <% Current.event.community_partners.with_attached_logo.each do |partner| %>
      <% if partner.url.present? %>
        <%= link_to partner.url, title: partner.name, class: "flex justify-center w-full h-16 p-2 bg-brand-card border-2 border-brand-line rounded-md transition ease-in-out hover:shadow-brutal hover:-translate-x-1 hover:-translate-y-1" do %>
          <%= image_tag try_variant(partner.logo, resize_to_limit: [500, 500]),
            class: "w-auto h-full object-contain",
            alt: partner.name,
            lazy: true %>
        <% end %>
      <% else %>
        <div title="<%= partner.name %>" class="flex justify-center w-full h-16 p-2 bg-brand-card border-2 border-brand-line rounded-md">
          <%= image_tag try_variant(partner.logo, resize_to_limit: [500, 500]),
            class: "w-auto h-full object-contain",
            alt: partner.name,
            lazy: true %>
        </div>
      <% end %>
    <% end %>
  </div>
<% end %>
