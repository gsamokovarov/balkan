<% title "Jobs" %>

<%= render "section", title: "Jobs", title_element: "h1", highlight: true do %>
  <% if @job_postings.any? %>
    <div class="space-y-12">
      <% @job_postings.group_by(&:sponsor).each do |sponsor, job_postings| %>
        <div class="space-y-4">
          <div class="flex items-center gap-3">
            <%= image_tag try_variant(sponsor.logo, resize_to_limit: [500, 500]),
              class: "w-10 h-10 object-contain shrink-0" %>
            <h2 class="text-xl font-extrabold"><%= sponsor.name %></h2>
          </div>

          <div class="space-y-3">
            <% job_postings.each do |job_posting| %>
              <%= link_to job_path(job_posting), class: "block p-4 bg-white border-2 border-black rounded-md transition ease-in-out hover:shadow-brutal hover:-translate-x-1 hover:-translate-y-1" do %>
                <h3 class="text-lg font-bold text-black"><%= job_posting.title %></h3>
                <p class="mt-1 text-gray-600 line-clamp-2"><%= render_plain truncate(job_posting.description, length: 200) %></p>
              <% end %>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="w-full rounded-lg border-2 border-dashed border-gray-300 p-12 text-center">
      <h3 class="mt-2 text-xl font-semibold text-gray-900">Nothing to show</h3>
    </div>
  <% end %>
<% end %>

<%= render "sponsors/sponsors" %>
<%= render "tickets/cta", highlight: true %>
